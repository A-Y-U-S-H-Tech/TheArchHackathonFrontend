# Backend API location. The monolithic FastAPI backend's host (IP or domain) and port.
# Used to build the base URL for every API call from the frontend.
# Examples:
#   NEXT_PUBLIC_API_HOST=127.0.0.1
#   NEXT_PUBLIC_API_PORT=8000
#   NEXT_PUBLIC_API_PROTOCOL=http
#
# In production (Vercel), set these in Project Settings -> Environment Variables.
# If your backend is served behind a domain with HTTPS already, you can instead
# just set NEXT_PUBLIC_API_BASE_URL directly and leave HOST/PORT unset.

NEXT_PUBLIC_API_PROTOCOL=http
NEXT_PUBLIC_API_HOST=127.0.0.1
NEXT_PUBLIC_API_PORT=8080

# Optional: overrides HOST/PORT/PROTOCOL entirely if set (e.g. https://api.mybackend.com)
# NEXT_PUBLIC_API_BASE_URL=
